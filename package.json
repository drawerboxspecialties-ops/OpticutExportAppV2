{
  "name": "opticut-export-app",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Local browser tool for converting Allmoxy CSV exports into Weinig OptiCut-ready cut-list CSV files and shop-floor stack sheets.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js,.mjs",
    "lint:fix": "eslint . --ext .js,.mjs --fix",
    "format": "prettier --write \"**/*.{js,mjs,css,html,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,css,html,md,json}\""
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "jszip": "^3.10.1",
    "prettier": "^3.3.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
